RewriteEngine On

# Serve clean URLs (internal rewrite)
RewriteRule ^thank-you/?$ thank-you.html [L]
RewriteRule ^terms-and-conditions/?$ terms.html [L]
RewriteRule ^privacy-policy/?$ privacy.html [L]
RewriteRule ^pdpa/?$ pdpa.html [L]

# Redirect old .html URLs to clean paths
RewriteCond %{THE_REQUEST} \s/index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

RewriteCond %{THE_REQUEST} \s/thank-you\.html[\s?] [NC]
RewriteRule ^thank-you\.html$ /thank-you [R=301,L]

RewriteCond %{THE_REQUEST} \s/terms\.html[\s?] [NC]
RewriteRule ^terms\.html$ /terms-and-conditions [R=301,L]

RewriteCond %{THE_REQUEST} \s/privacy\.html[\s?] [NC]
RewriteRule ^privacy\.html$ /privacy-policy [R=301,L]

RewriteCond %{THE_REQUEST} \s/pdpa\.html[\s?] [NC]
RewriteRule ^pdpa\.html$ /pdpa [R=301,L]
